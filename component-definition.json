{
  "groups": [
    {
      "title": "Content",
      "id": "content",
      "components": [
        {
          "title": "Hero",
          "id": "hero",
          "plugins": {
            "da": {
              "name": "Hero",
              "rows": 2,
              "columns": 1,
              "fields": [
                {
                  "name": "image",
                  "selector": "div:nth-child(1) > div > picture > img[src]"
                },
                {
                  "name": "imageAlt",
                  "selector": "div:nth-child(1) > div > picture > img[alt]"
                },
                {
                  "name": "text",
                  "selector": "div:nth-child(2) > div"
                }
              ]
            }
          },
          "model": "hero"
        },
        {
          "title": "Alert Banner",
          "id": "alert-banner",
          "plugins": {
            "da": {
              "name": "Alert Banner",
              "rows": 1,
              "columns": 1
            }
          },
          "model": "alert-banner"
        },
        {
